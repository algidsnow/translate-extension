{
  "manifest_version": 3,
  "name": "Gemini Vocab Helper",
  "version": "2.0",
  "description": "Bôi đen từ để dịch và lưu với Gemini.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}